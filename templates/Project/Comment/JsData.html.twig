<div class="js-project-comments"
     data-project-id="{{ project.id }}"
     data-current-user-id="{{ app.user ? app.user.id : '' }}"
     data-is-admin="{{ is_granted('ROLE_ADMIN') ? 'true' : 'false' }}"
     data-trans-cancel="{{ 'cancel'|trans({}, 'catroweb') }}"
     data-trans-delete-it="{{ 'deleteIt'|trans({}, 'catroweb') }}"
     data-trans-report-it="{{ 'reportIt'|trans({}, 'catroweb') }}"
     data-trans-are-you-sure="{{ 'areYouSure'|trans({}, 'catroweb') }}"
     data-trans-no-way-of-return="{{ 'noWayOfReturn'|trans({}, 'catroweb') }}"
     data-trans-delete-confirmation="{{ 'project.deleteCommentConfirmation'|trans({}, 'catroweb') }}"
     data-trans-report-confirmation="{{ 'project.reportCommentConfirmation'|trans({}, 'catroweb') }}"
     data-trans-pop-up-comment-reported-title="{{ 'project.report_popup_header'|trans({}, 'catroweb') }}"
     data-trans-pop-up-comment-reported-text="{{ 'project.report_popup'|trans({}, 'catroweb') }}"
     data-trans-pop-up-deleted-title="{{ 'project.deleted_popup_header'|trans({}, 'catroweb') }}"
     data-trans-pop-up-deleted-text="{{ 'project.deleted_popup'|trans({}, 'catroweb') }}"
     data-trans-deleted-comment="{{ 'project.deletedComment'|trans({}, 'catroweb') }}"
     data-trans-no-admin-rights-message="{{ 'project.noAdminRights'|trans({}, 'catroweb') }}"
     data-trans-default-error-message="{{ 'somethingWentWrong'|trans({}, 'catroweb') }}"
     data-trans-reply="{{ 'project.reply'|trans({}, 'catroweb') }}"
     data-trans-show-translation="{{ 'project.showTranslation'|trans({}, 'catroweb') }}"
     data-trans-hide-translation="{{ 'project.hideTranslation'|trans({}, 'catroweb') }}"
     data-trans-report="{{ 'project.report'|trans({}, 'catroweb') }}"
     data-trans-delete-comment="{{ 'project.delete'|trans({}, 'catroweb') }}"
     data-comment-detail-url-template="{{ path('project_comment', {id: '__COMMENT_ID__', theme: app.request.attributes.get('flavor')|default('pocketcode')}) }}"
     data-profile-url-template="{{ url('profile', {id: '__USER_ID__', theme: app.request.attributes.get('flavor')|default('pocketcode')}) }}"
     data-translate-comment-url-template="{{ path('open_api_server_comments_commentsidtranslationget', {id: '__COMMENT_ID__'}) }}"
     data-trans-account-not-verified="{{ 'accountNotVerified'|trans({}, 'catroweb') }}"
     data-trans-account-suspended="{{ 'accountSuspended'|trans({}, 'catroweb') }}"
     data-trans-rate-limited="{{ 'moderation.comment.rate_limited'|trans({}, 'catroweb') }}"
     data-trans-report-unverified="{{ 'moderation.report.unverified'|trans({}, 'catroweb') }}"
     data-trans-report-suspended="{{ 'accountSuspended'|trans({}, 'catroweb') }}"
     data-path-comments-list-url="{{ path('open_api_server_comments_projectidcommentsget', {id: project.id}) }}"
     data-path-comments-base-url="{{ path('open_api_server_comments_commentsiddelete', {id: 0})|replace({'/0': ''}) }}"
     data-path-login-url="{{ path('login') }}"
     data-translated-by-line="{{ 'project.translatedByLine'|trans({}, 'catroweb') }}"
     data-google-translate-display-name="{{ 'project.googleTranslate'|trans({}, 'catroweb') }}"
     data-trans-report-title="{{ 'moderation.report.title'|trans({'%content_type%': 'comment'}, 'catroweb') }}"
     data-trans-report-submit="{{ 'moderation.report.submit'|trans({}, 'catroweb') }}"
     data-trans-report-cancel="{{ 'cancel'|trans({}, 'catroweb') }}"
     data-trans-report-success="{{ 'moderation.report.success'|trans({}, 'catroweb') }}"
     data-trans-report-error="{{ 'moderation.report.error'|trans({}, 'catroweb') }}"
     data-trans-report-duplicate="{{ 'moderation.report.duplicate'|trans({}, 'catroweb') }}"
     data-trans-report-trust-too-low="{{ 'moderation.report.trust_too_low'|trans({}, 'catroweb') }}"
     data-trans-report-rate-limited="{{ 'moderation.report.rate_limited'|trans({}, 'catroweb') }}"
     data-trans-report-placeholder="{{ 'moderation.report.reason_placeholder'|trans({}, 'catroweb') }}"
     data-is-logged-in="{{ app.user ? 'true' : 'false' }}">
</div>
