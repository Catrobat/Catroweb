<div id="details">

  <h2 class="mt-3">
    {{ "projectDetails"|trans({}, "catroweb") }}
  </h2>

  <div class="row">
    <div class="col-6 col-lg-4 mt-2 mb-2 no-overflow">
      <i class="material-icons">visibility</i>
      <span class="icon-text ms-2 align-bottom">{{ "project.views"|trans({ '%views%' : project_details.views }, "catroweb") }}</span>
    </div>
    <div class="col-6 col-lg-4 mt-2 mb-2 no-overflow">
      <i class="material-icons">query_builder</i>
      <span class="icon-text ms-2 align-bottom">{{ project_details.age }}</span>
    </div>
    <div class="d-none d-lg-block col-lg-4">
      {% include 'components/redirect_button.twig' with {
        'id': 'projectCodeStatsButton',
        'url': path('code_statistics', {'id': project.id }),
        'icon': 'show_chart',
        'text': "statistics"|trans({}, "catroweb")
      } %}
    </div>
  </div>

  <div class="row">
    <div class="col-6 col-lg-4 mt-2 mb-2 no-overflow mt-lg-3">
      <i class="material-icons">description</i>
      <span class="icon-text ms-2">{{ project_details.filesize }} MB</span>
    </div>
    <div class="col-6 col-lg-4 mt-2 mb-2 no-overflow mt-lg-3">
      <i class="material-icons ">get_app</i>
      <span class="icon-text ms-2">{{ "project.downloads"|trans({ '%downloads%' : project_details.downloads }, "catroweb") }}</span>
    </div>
    <div class="d-none d-lg-block col-lg-4 mt-2">
      {% include 'components/redirect_button.twig' with {
        'id': 'projectCodeViewButton',
        'url': path('code_view', {'id': project.id }),
        'icon': 'extension',
        'text': "codeview.title"|trans({}, "catroweb")
      } %}
    </div>
  </div>
  {% if logged_in %}
  <div class="btn btn-danger d-lg-block col-lg-3 mt-2">
        {% include 'components/redirect_button.twig' with {
        'id': 'projectStealButton',
        'url': path('project_steal', {'id': project.id }),
        'icon': 'person',
        'text': "Steal"
      } %}
      <aside class="mdc-snackbar">
        <div class="mdc-snackbar__surface" role="status" aria-relevant="additions">
          <div class="mdc-snackbar__label" aria-atomic="false">
            Can't send photo. Retry in 5 seconds.
          </div>
          <div class="mdc-snackbar__actions" aria-atomic="true">
            <button type="button" class="mdc-button mdc-snackbar__action">
              <div class="mdc-button__ripple"></div>
              <span class="mdc-button__label">Retry</span>
            </button>
          </div>
        </div>
      </aside>
    </div>
  {% endif %}

  {% if project.getNotForKids() %}
  <div class="row">
    <div class="col-6 col-lg-4 mt-2 mb-2 no-overflow">
      <img alt="Not for Kids" id="not-for-kids-logo" src="{{ asset('images/default/not_for_kids.svg') }}" style="width: 24px; height: 24px;">
      <span id="notForKidsText" class="icon-text ms-2 align-bottom">{{ "project.notForKids"|trans({}, "catroweb") }}</span>
    </div>
  </div>
  {% endif %}

  <div class="row mb-4">
    <div class="col-6 mb-3 d-lg-none mt-3">
      {% include 'components/redirect_button.twig' with {
        'id': 'projectCodeStatsButton',
        'suffix': '-small',
        'url': path('code_statistics', {'id': project.id }),
        'icon': 'show_chart',
        'text': "statistics"|trans({}, "catroweb")
      } %}
    </div>
    <div class="col-6 mb-3 d-lg-none mt-3">
      {% include 'components/redirect_button.twig' with {
        'id': 'projectCodeViewButton',
        'suffix': '-small',
        'url': path('code_view', {'id': project.id }),
        'icon': 'extension',
        'text': "codeview.title"|trans({}, "catroweb")
      } %}
    </div>
  </div>

</div>
