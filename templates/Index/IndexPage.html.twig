{% extends 'Layout/Base.html.twig' %}
{% import 'Components/ResponsiveImage.html.twig' as responsive_image %}

{% block head %}
  {{ encore_entry_link_tags('index_page') }}
  {% if first_banner is defined and first_banner %}
    {% set _preload_url = (first_banner.image_variants and first_banner.image_variants.detail and first_banner.image_variants.detail.webp1x)
        ? first_banner.image_variants.detail.webp1x
        : first_banner.image_url %}
    <link rel="preload" as="image" href="{{ _preload_url }}" fetchpriority="high">
  {% endif %}
{% endblock %}

{% block body %}

  <div id="maintenance-container"
       data-maintenance-url="{{ path('maintenance_list') }}"
       data-close-url-template="{{ path('close_maintenance_view', {viewId: '__ID__'}) }}"
  ></div>

  <div id="featured-slider" class="featured-slider"
       style="display: grid;"
       data-base-url="{{ app.request.getBaseURL() }}"
       data-theme="{{ theme() }}"
       data-flavor="{{ flavor() }}"
       data-is-guest="{{ app.user ? '0' : '1' }}"
       data-is-webview="{{ isWebview() ? '1' : '0' }}"
       data-trans-featured="{{ 'project.featured'|trans({}, 'catroweb') }}"
  >
    {% if first_banner is defined and first_banner %}
      <div class="featured-slider__ssr featured-banner mb-2" style="grid-area: 1/1;">
        {% set _has_variants = first_banner.image_variants and first_banner.image_variants.detail and first_banner.image_variants.detail.webp1x %}
        {% if first_banner.link_url %}
          <a href="{{ first_banner.link_url }}">
            {% if _has_variants %}
              {{ responsive_image.picture(
                first_banner.image_variants,
                first_banner.title,
                {
                  class: 'carousel-item__image d-block w-100',
                  sizes: '(min-width: 1200px) 960px, 100vw',
                  loading: 'eager',
                  fetchpriority: 'high',
                  fallback: first_banner.image_url,
                },
              ) }}
            {% else %}
              <img src="{{ first_banner.image_url }}"
                   class="carousel-item__image d-block w-100"
                   alt="{{ first_banner.title }}"
                   width="960" height="563"
                   fetchpriority="high">
            {% endif %}
          </a>
        {% else %}
          <div>
            {% if _has_variants %}
              {{ responsive_image.picture(
                first_banner.image_variants,
                first_banner.title,
                {
                  class: 'carousel-item__image d-block w-100',
                  sizes: '(min-width: 1200px) 960px, 100vw',
                  loading: 'eager',
                  fetchpriority: 'high',
                  fallback: first_banner.image_url,
                },
              ) }}
            {% else %}
              <img src="{{ first_banner.image_url }}"
                   class="carousel-item__image d-block w-100"
                   alt="{{ first_banner.title }}"
                   width="960" height="563"
                   fetchpriority="high">
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% else %}
      <div class="featured-slider__skeleton featured-banner mb-2" style="grid-area: 1/1;">
        <div style="aspect-ratio: 1024/600;"></div>
      </div>
    {% endif %}
  </div>

  <div id="home-projects">
    {# array values: [api project_type, translation, property to show] #}
    {# disabled due to performance issues: ['recent', 'newest', 'uploaded'], #}

    {% if isWebview() %}
      {% set categories = [
        ['trending', 'trending', 'author'],
        ['popular', 'popular', 'author'],
        ['example', 'example', 'author'],
      ] %}
    {% elseif app.user %}
      {% set categories = [
        ['trending', 'trending', 'author'],
        ['_studios_', null, null],
        ['popular', 'popular', 'author'],
        ['example', 'example', 'author'],
      ] %}
    {% else %}
      {% set categories = [
        ['trending', 'trending', 'author'],
        ['random', 'random', 'uploaded'],
        ['_studios_', null, null],
        ['popular', 'popular', 'author'],
        ['example', 'example', 'author'],
      ] %}
    {% endif %}

    {% if app.user %}
      <div id="home-projects__my_projects" data-category="my_projects" data-property="uploaded"
           data-theme="{{ theme() }}" data-flavor="{{ flavor() }}" data-base-url="{{ app.request.getBaseURL() }}"
           data-url="{{ app.request.getBaseURL() }}/api/projects/user/{{ app.user.id }}"
           class="project-list home-section loading horizontal">
        <div class="container">
          <div class="project-list__title">
            <h2>{{ 'project.my_projects'|trans({}, 'catroweb') }}</h2>
            <div class="project-list__title__btn-toggle btn-view-open">
              <div class="project-list__title__btn-toggle__text">{{ 'show-more'|trans({}, 'catroweb') }}</div>
              <div class="project-list__title__btn-toggle__icon material-icons">arrow_forward</div>
            </div>
          </div>
          <div class="lazyloaded project-list__wrapper">
            <div class="lazyloaded projects-container">

              {% for i in range(0, 10) %}
                <div class="project-list__project">
                  <img src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%20360%20360'%3E%3Crect%20width='360'%20height='360'%20fill='%23E8E8E8'%20/%3E%3C/svg%3E"
                       class="project-list__project__image" alt="" width="360" height="360">
                  <span class="project-list__project__name"><span class="skeleton-bar skeleton-bar--lg" style="width: 70%"></span></span>
                  <div class="project-list__project__property project-list__project__property-uploaded lazyloaded">
                    <span class="skeleton-bar" style="width: 55%"></span>
                  </div>
                  <div class="project-list__meta-secondary"><span class="skeleton-bar skeleton-bar--sm" style="width: 35%"></span></div>
                  <span class="projects-meta__item projects-meta__item--retention"><span class="skeleton-bar skeleton-bar--sm" style="width: 45%"></span></span>
                </div>
              {% endfor %}

            </div>
            <div class="lazyloaded project-list__chevrons">
              <div class="lazyloaded project-list__chevrons__left material-icons mdc-icon-button" style="display: none;">
                chevron_left
              </div>
              <div class="lazyloaded project-list__chevrons__right material-icons mdc-icon-button">chevron_right</div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {% set placeholder_svg = "data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%20360%20360'%3E%3Crect%20width='360'%20height='360'%20fill='%23E8E8E8'%20/%3E%3C/svg%3E" %}

    {% for category in categories %}
      {% if category[0] == '_studios_' %}
        {# Studios section — uses same ProjectList component with card-type=studio #}
        <div id="popular-studios" data-category="popular_studios" data-property="members"
             data-card-type="studio" data-theme="{{ theme() }}" data-flavor="{{ flavor() }}"
             data-base-url="{{ app.request.getBaseURL() }}"
             data-url="{{ app.request.getBaseURL() }}/api/studios"
             data-fetch-count="10"
             data-trans-members="{{ 'members'|trans({}, 'catroweb') }}"
             class="project-list home-section home-section--accent loading horizontal">
          <div class="container">
            <div class="project-list__title">
              <h2>{{ 'studio.popular'|trans({}, 'catroweb') }}</h2>
              <div class="project-list__title__btn-toggle btn-view-open">
                <div class="project-list__title__btn-toggle__text">{{ 'show-more'|trans({}, 'catroweb') }}</div>
                <div class="project-list__title__btn-toggle__icon material-icons">arrow_forward</div>
              </div>
            </div>
            <div class="lazyloaded project-list__wrapper">
              <div class="lazyloaded projects-container">
                {% for i in range(0, 5) %}
                  <div class="project-list__project">
                    <img src="{{ placeholder_svg }}" class="project-list__project__image" alt="" width="360" height="360">
                    <span class="project-list__project__name"><span class="skeleton-bar skeleton-bar--lg" style="width: 65%"></span></span>
                    <div class="project-list__project__property project-list__project__property-members lazyloaded">
                      <span class="skeleton-bar" style="width: 50%"></span>
                    </div>
                  </div>
                {% endfor %}
              </div>
              <div class="lazyloaded project-list__chevrons">
                <div class="lazyloaded project-list__chevrons__left material-icons mdc-icon-button" style="display: none;">chevron_left</div>
                <div class="lazyloaded project-list__chevrons__right material-icons mdc-icon-button">chevron_right</div>
              </div>
            </div>
          </div>
        </div>
      {% else %}
        <div id="home-projects__{{ category[0] }}" data-category="{{ category[0] }}" data-property="{{ category[2] }}"
             data-theme="{{ theme() }}" data-flavor="{{ flavor() }}" data-base-url="{{ app.request.getBaseURL() }}"
             class="project-list home-section loading horizontal">
          <div class="container">
            <div class="project-list__title">
              <h2>{{ ('project.' ~ category[1])|trans({}, 'catroweb') }}</h2>
              <div class="project-list__title__btn-toggle btn-view-open">
                <div class="project-list__title__btn-toggle__text">{{ 'show-more'|trans({}, 'catroweb') }}</div>
                <div class="project-list__title__btn-toggle__icon material-icons">arrow_forward</div>
              </div>
            </div>
            <div class="lazyloaded project-list__wrapper">
              <div class="lazyloaded projects-container">
                {% for i in range(0, 10) %}
                  <div class="project-list__project">
                    <img src="{{ placeholder_svg }}" class="project-list__project__image" alt="" width="360" height="360">
                    <span class="project-list__project__name"><span class="skeleton-bar skeleton-bar--lg" style="width: 70%"></span></span>
                    <div class="project-list__project__property project-list__project__property-uploaded lazyloaded">
                      <span class="skeleton-bar" style="width: 55%"></span>
                    </div>
                    <div class="project-list__meta-secondary"><span class="skeleton-bar skeleton-bar--sm" style="width: 35%"></span></div>
                    <span class="projects-meta__item projects-meta__item--retention"><span class="skeleton-bar skeleton-bar--sm" style="width: 45%"></span></span>
                  </div>
                {% endfor %}
              </div>
              <div class="lazyloaded project-list__chevrons">
                <div class="lazyloaded project-list__chevrons__left material-icons mdc-icon-button" style="display: none;">chevron_left</div>
                <div class="lazyloaded project-list__chevrons__right material-icons mdc-icon-button">chevron_right</div>
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <i class="material-icons d-none" id="project-opening-spinner" style="margin: auto;">
    {{ include('Components/LoadingSpinner.html.twig', {spinner_id: 'project-opening-spinner' ~ suffix|default(), small: 'true'}) }}
  </i>

  <div class="js-trans-ok" data-trans-ok="'{{ 'ok'|trans({}, 'catroweb') }}"></div>

  <div class="js-oauth-greeting"
       data-is-first-oauth-login="{{ is_first_oauth_login }}"
       data-trans-title="{{ 'oauthPopUpTitle'|trans({}, 'catroweb') }}"
       data-trans-info="{{ 'oauthInfo'|trans({}, 'catroweb') }}"
       data-trans-ok="{{ 'ok'|trans({}, 'catroweb') }}"
  ></div>
{% endblock %}

{% block javascript %}
  {{ encore_entry_script_tags('index_page') }}
{% endblock %}
