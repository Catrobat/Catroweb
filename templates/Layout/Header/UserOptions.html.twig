{% if '/user/' in app.request.pathinfo and profile|default(false) and profile.id|default(false) %}

  <li id="top-app-bar__btn-share"
      class="mdc-deprecated-list-item"
      role="menuitem"
      data-clipboard-text="{{ url('profile', {id: profile.id}) }}">
    <span class="mdc-deprecated-list-item__ripple"></span>
    <span class="mdc-deprecated-list-item__graphic material-icons">share</span>
    <span class="mdc-deprecated-list-item__text" id="top-app-bar__btn-share-text">{{ 'share.text'|trans({}, 'catroweb') }}</span>
  </li>

  {% if (app.user is null or app.user.id != profile.id) and not profile.approved %}
    <li id="top-app-bar__btn-report-user"
        class="mdc-deprecated-list-item"
        role="menuitem"
        data-content-type="user"
        data-content-id="{{ profile.id }}"
        data-report-url="{{ url('open_api_server_moderation_useridreportpost', {id: profile.id}) }}"
        data-login-url="{{ url('login') }}"
        data-logged-in="{{ app.user ? 'true' : 'false' }}"
        data-trans-report-title="{{ 'moderation.report.title'|trans({'%content_type%': 'user'}, 'catroweb') }}"
        data-trans-report-submit="{{ 'moderation.report.submit'|trans({}, 'catroweb') }}"
        data-trans-report-cancel="{{ 'cancel'|trans({}, 'catroweb') }}"
        data-trans-report-success="{{ 'moderation.report.success'|trans({}, 'catroweb') }}"
        data-trans-report-error="{{ 'moderation.report.error'|trans({}, 'catroweb') }}"
        data-trans-report-duplicate="{{ 'moderation.report.duplicate'|trans({}, 'catroweb') }}"
        data-trans-report-trust-too-low="{{ 'moderation.report.trust_too_low'|trans({}, 'catroweb') }}"
        data-trans-report-unverified="{{ 'moderation.report.unverified'|trans({}, 'catroweb') }}"
        data-trans-report-suspended="{{ 'accountSuspended'|trans({}, 'catroweb') }}"
        data-trans-report-rate-limited="{{ 'moderation.report.rate_limited'|trans({}, 'catroweb') }}"
        data-trans-report-placeholder="{{ 'moderation.report.reason_placeholder'|trans({}, 'catroweb') }}">
      <span class="mdc-deprecated-list-item__ripple"></span>
      <span class="mdc-deprecated-list-item__graphic material-icons">flag</span>
      <span class="mdc-deprecated-list-item__text">{{ 'report'|trans({}, 'catroweb') }}</span>
    </li>
  {% endif %}

{% endif %}
