{% if '/project/' in app.request.pathinfo and project|default(false) and project.id|default(false) %}
  {% set page_context = 'project' %}
{% elseif '/studio/' in app.request.pathinfo and studio|default(false) and studio.id|default(false) %}
  {% set page_context = 'studio' %}
{% elseif '/user/' in app.request.pathinfo and profile|default(false) and profile.id|default(false) %}
  {% set page_context = 'user' %}
{% elseif app.request.attributes.get('_route') == 'profile' and app.request.attributes.get('id', 0) == 0 %}
  {% set page_context = 'my_profile' %}
{% else %}
  {% set page_context = 'default' %}
{% endif %}

{% set color_scheme_title = 'color-scheme.title'|trans({}, 'catroweb') %}
{% if color_scheme_title == 'color-scheme.title' %}
  {% set color_scheme_title = 'Theme' %}
{% endif %}
{% set color_scheme_light_description = 'color-scheme.light_description'|trans({}, 'catroweb') %}
{% if color_scheme_light_description == 'color-scheme.light_description' %}
  {% set color_scheme_light_description = 'Bright appearance' %}
{% endif %}
{% set color_scheme_dark_description = 'color-scheme.dark_description'|trans({}, 'catroweb') %}
{% if color_scheme_dark_description == 'color-scheme.dark_description' %}
  {% set color_scheme_dark_description = 'Dark appearance' %}
{% endif %}
{% set color_scheme_auto_description = 'color-scheme.auto_description'|trans({}, 'catroweb') %}
{% if color_scheme_auto_description == 'color-scheme.auto_description' %}
  {% set color_scheme_auto_description = 'Follow your device setting' %}
{% endif %}
{% set color_scheme_apply = 'color-scheme.apply'|trans({}, 'catroweb') %}
{% if color_scheme_apply == 'color-scheme.apply' %}
  {% set color_scheme_apply = 'Apply' %}
{% endif %}

{# Studio admin settings modal — included here so the menu item can open it #}
{% if page_context == 'studio' %}
  {{ include('Studio/Details/AdminSettings.html.twig') }}
{% endif %}

{% if page_context == 'my_profile' %}
  <div class="mdc-touch-target-wrapper">
    <button id="top-app-bar__btn-settings" data-bs-toggle="modal" data-bs-target="#user-settings-modal"
            class="material-icons mdc-top-app-bar__action-item mdc-icon-button mdc-icon-button--touch "
            aria-label="{{ 'myprofile.userSettings'|trans({}, 'catroweb') }}">
      <div class="mdc-icon-button__ripple"></div>
      settings
      <div class="mdc-icon-button__touch"></div>
    </button>
  </div>
{% endif %}

{# Options menu with color scheme #}
  <div class="mdc-menu-surface--anchor">
    {{ include('Layout/Header/OptionButton.html.twig') }}

    <div id="top-app-bar__options-menu" class="mdc-menu mdc-menu-surface">
      <ul class="mdc-deprecated-list mdc-deprecated-list--icon-list" role="menu" aria-hidden="true"
          aria-orientation="vertical" tabindex="-1">

        {# Page-specific items #}
        {% if page_context == 'project' %}
          {{ include('Layout/Header/ProjectOptions.html.twig') }}
        {% elseif page_context == 'studio' %}
          <li id="top-app-bar__btn-edit-studio"
              class="mdc-deprecated-list-item js-studio-admin-only"
              role="menuitem"
              style="display: none"
              data-bs-toggle="modal"
              data-bs-target="#studio-admin-settings-modal">
            <span class="mdc-deprecated-list-item__ripple"></span>
            <span class="mdc-deprecated-list-item__graphic material-icons">edit</span>
            <span class="mdc-deprecated-list-item__text">{{ 'studio.details.admin_settings.title'|trans({}, 'catroweb') }}</span>
          </li>
          <div id="top-app-bar__studio-report-wrapper" class="js-studio-non-admin-only">
            {{ include('Layout/Header/StudioOptions.html.twig') }}
          </div>
        {% elseif page_context == 'user' %}
          {{ include('Layout/Header/UserOptions.html.twig') }}
        {% endif %}

        {# Divider between page-specific and share items #}
        {% if page_context in ['project', 'user', 'studio'] %}
          <li class="mdc-deprecated-list-divider" role="separator"></li>
        {% endif %}

        {# Share current page — hidden on personal/utility pages where sharing the URL is not useful #}
        {% set _no_share_routes = ['notifications', 'achievements_overview', 'catrobat_follower', 'user_reports'] %}
        {% if app.request.attributes.get('_route') not in _no_share_routes %}
        <li id="top-app-bar__btn-share-page" class="mdc-deprecated-list-item" role="menuitem"
            {% if page_context == 'my_profile' and app.user.id|default(false) %}
              data-share-url="{{ url('profile', {id: app.user.id}) }}"
            {% endif %}
            data-trans-share-success="{{ 'share.success'|trans({}, 'catroweb') }}"
            data-trans-clipboard-success="{{ 'clipboard.success'|trans({}, 'catroweb') }}"
            data-trans-clipboard-fail="{{ 'clipboard.fail'|trans({}, 'catroweb') }}">
          <span class="mdc-deprecated-list-item__ripple"></span>
          <span class="mdc-deprecated-list-item__graphic material-icons">share</span>
          <span class="mdc-deprecated-list-item__text">{{ 'share.text'|trans({}, 'catroweb') }}</span>
        </li>
        {% endif %}

        {# Divider between share and color scheme items #}
        <li class="mdc-deprecated-list-divider" role="separator"></li>

        {# Compact color scheme entry (always shown) #}
        <li id="top-app-bar__btn-color-scheme"
            class="mdc-deprecated-list-item"
            role="menuitem"
            data-trans-title="{{ color_scheme_title|e('html_attr') }}"
            data-trans-light="{{ 'color-scheme.light'|trans({}, 'catroweb')|e('html_attr') }}"
            data-trans-light-description="{{ color_scheme_light_description|e('html_attr') }}"
            data-trans-dark="{{ 'color-scheme.dark'|trans({}, 'catroweb')|e('html_attr') }}"
            data-trans-dark-description="{{ color_scheme_dark_description|e('html_attr') }}"
            data-trans-auto="{{ 'color-scheme.auto'|trans({}, 'catroweb')|e('html_attr') }}"
            data-trans-auto-description="{{ color_scheme_auto_description|e('html_attr') }}"
            data-trans-cancel="{{ 'cancelMessage'|trans({}, 'catroweb')|e('html_attr') }}"
            data-trans-confirm="{{ color_scheme_apply|e('html_attr') }}">
          <span class="mdc-deprecated-list-item__ripple"></span>
          <span class="mdc-deprecated-list-item__graphic material-icons js-color-scheme-icon">contrast</span>
          <span class="mdc-deprecated-list-item__text">{{ color_scheme_title }}</span>
          <span class="mdc-deprecated-list-item__meta js-color-scheme-current"></span>
        </li>

      </ul>
    </div>
  </div>
