{% if '/project/' in app.request.pathinfo and project|default(false) and project.id|default(false) %}
  {% set page_context = 'project' %}
{% elseif '/studio/' in app.request.pathinfo and studio|default(false) and studio.id|default(false) %}
  {% set page_context = 'studio' %}
{% elseif '/user/' in app.request.pathinfo and profile|default(false) and profile.id|default(false) %}
  {% set page_context = 'user' %}
{% elseif app.request.pathinfo == '/app/user' %}
  {% set page_context = 'my_profile' %}
{% else %}
  {% set page_context = 'default' %}
{% endif %}

{# Studio admin pages show settings button alongside options menu #}
{% if page_context == 'studio' and user_role == 'admin' %}
  <div class="mdc-touch-target-wrapper">
    <button id="top-app-bar__btn-settings" data-bs-toggle="modal" data-bs-target="#studio-admin-settings-modal"
            class="material-icons mdc-top-app-bar__action-item mdc-icon-button mdc-icon-button--touch"
            aria-label="Search">
      <div class="mdc-icon-button__ripple"></div>
      settings
      <div class="mdc-icon-button__touch"></div>
    </button>
  </div>
  {{ include('Studio/Details/AdminSettings.html.twig') }}
{% endif %}

{% if page_context == 'my_profile' %}
  <div class="mdc-touch-target-wrapper">
    <button id="top-app-bar__btn-settings" data-bs-toggle="modal" data-bs-target="#user-settings-modal"
            class="material-icons mdc-top-app-bar__action-item mdc-icon-button mdc-icon-button--touch "
            aria-label="{{ 'myprofile.userSettings'|trans({}, 'catroweb') }}">
      <div class="mdc-icon-button__ripple"></div>
      settings
      <div class="mdc-icon-button__touch"></div>
    </button>
  </div>
{% endif %}

{# Options menu with color scheme (always shown, except studio admin which uses settings button for studio-specific actions) #}
{% if page_context != 'studio' or user_role != 'admin' %}
  <div class="mdc-menu-surface--anchor">
    {{ include('Layout/Header/OptionButton.html.twig') }}

    <div id="top-app-bar__options-menu" class="mdc-menu mdc-menu-surface">
      <ul class="mdc-deprecated-list mdc-deprecated-list--icon-list" role="menu" aria-hidden="true"
          aria-orientation="vertical" tabindex="-1">

        {# Page-specific items #}
        {% if page_context == 'project' %}
          {{ include('Layout/Header/ProjectOptions.html.twig') }}
        {% elseif page_context == 'studio' %}
          {{ include('Layout/Header/StudioOptions.html.twig') }}
        {% elseif page_context == 'user' %}
          {{ include('Layout/Header/UserOptions.html.twig') }}
        {% endif %}

        {# Divider between page-specific and share items #}
        {% if page_context in ['project', 'studio', 'user'] %}
          <li class="mdc-deprecated-list-divider" role="separator"></li>
        {% endif %}

        {# Share current page (always shown) #}
        <li id="top-app-bar__btn-share-page" class="mdc-deprecated-list-item" role="menuitem"
            {% if page_context == 'my_profile' and app.user.id|default(false) %}
              data-share-url="{{ url('profile', {id: app.user.id}) }}"
            {% endif %}
            data-trans-share-success="{{ 'share.success'|trans({}, 'catroweb') }}"
            data-trans-clipboard-success="{{ 'clipboard.success'|trans({}, 'catroweb') }}"
            data-trans-clipboard-fail="{{ 'clipboard.fail'|trans({}, 'catroweb') }}">
          <span class="mdc-deprecated-list-item__ripple"></span>
          <span class="mdc-deprecated-list-item__graphic material-icons">share</span>
          <span class="mdc-deprecated-list-item__text">{{ 'share.text'|trans({}, 'catroweb') }}</span>
        </li>

        {# Divider between page-specific/share and color scheme items #}
        <li class="mdc-deprecated-list-divider" role="separator"></li>

        {# Color scheme items (always shown) #}
        <li class="mdc-deprecated-list-item" role="menuitem" data-value="light">
          <span class="mdc-deprecated-list-item__ripple"></span>
          <span class="mdc-deprecated-list-item__graphic material-icons">light_mode</span>
          <span class="mdc-deprecated-list-item__text">{{ 'color-scheme.light'|trans({}, 'catroweb') }}</span>
        </li>
        <li class="mdc-deprecated-list-item" role="menuitem" data-value="dark">
          <span class="mdc-deprecated-list-item__ripple"></span>
          <span class="mdc-deprecated-list-item__graphic material-icons">dark_mode</span>
          <span class="mdc-deprecated-list-item__text">{{ 'color-scheme.dark'|trans({}, 'catroweb') }}</span>
        </li>
        <li class="mdc-deprecated-list-item" role="menuitem" data-value="auto">
          <span class="mdc-deprecated-list-item__ripple"></span>
          <span class="mdc-deprecated-list-item__graphic material-icons">contrast</span>
          <span class="mdc-deprecated-list-item__text">{{ 'color-scheme.auto'|trans({}, 'catroweb') }}</span>
        </li>

      </ul>
    </div>
  </div>
{% endif %}
