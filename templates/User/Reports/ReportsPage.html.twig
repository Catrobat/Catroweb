{% extends 'Layout/Base.html.twig' %}
{% block top_bar_page_title %}{{ 'My Reports'|trans({}, 'catroweb') }}{% endblock %}

{% block head %}
  {{ encore_entry_link_tags('user_reports_page') }}
{% endblock %}

{% block body %}

  {{ include('Components/ChipSet.html.twig', {
    chips: [
      {
        id: 'all-reports',
        icon: 'flag',
        title: '' ~ 'All'|trans({}, 'catroweb'),
        controls: 'reports-all',
      },
      {
        id: 'pending-reports',
        icon: 'hourglass_empty',
        title: '' ~ 'Pending'|trans({}, 'catroweb'),
        controls: 'reports-pending',
      },
      {
        id: 'accepted-reports',
        icon: 'check_circle',
        title: '' ~ 'Accepted'|trans({}, 'catroweb'),
        controls: 'reports-accepted',
      },
      {
        id: 'rejected-reports',
        icon: 'cancel',
        title: '' ~ 'Rejected'|trans({}, 'catroweb'),
        controls: 'reports-rejected',
      },
    ],
  }) }}

  <div class="tab-content mt-4">
    {% for category in [
      {
        id: 'reports-all',
        emptyID: 'no-reports-all',
        emptyMessage: '' ~ 'You haven\'t filed any reports yet.'|trans({}, 'catroweb'),
      },
      {
        id: 'reports-pending',
        emptyID: 'no-reports-pending',
        emptyMessage: '' ~ 'No pending reports.'|trans({}, 'catroweb'),
      },
      {
        id: 'reports-accepted',
        emptyID: 'no-reports-accepted',
        emptyMessage: '' ~ 'No accepted reports.'|trans({}, 'catroweb'),
      },
      {
        id: 'reports-rejected',
        emptyID: 'no-reports-rejected',
        emptyMessage: '' ~ 'No rejected reports.'|trans({}, 'catroweb'),
      },
    ] %}
    <div id="{{ category.id }}" class="tab-pane fade {% if loop.first %} show active {% endif %}" role="tabpanel">
      {% if loop.first %}
        {% for i in range(0, 3) %}
          <div class="report-item js-skeleton">
            <div class="report-card">
              <div class="report-icon">
                <span class="skeleton" style="display: block; width: 48px; height: 48px; border-radius: 50%;"></span>
              </div>
              <div class="report-content" style="flex: 1;">
                <span class="skeleton" style="display: inline-block; width: {{ [50, 40, 55, 45][i] }}%; height: 0.9rem;"></span>
                <div style="margin-top: 0.3rem;">
                  <span class="skeleton" style="display: inline-block; width: {{ [35, 30, 40, 25][i] }}%; height: 0.75rem;"></span>
                </div>
                <div style="margin-top: 0.25rem;">
                  <span class="skeleton" style="display: inline-block; width: 20%; height: 0.7rem;"></span>
                </div>
              </div>
              <div class="report-status">
                <span class="skeleton" style="display: inline-block; width: 60px; height: 1.25rem; border-radius: 1rem;"></span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
      <div class="no-reports text-center mb-5 d-none">
        <span id="{{ category.emptyID }}">{{ category.emptyMessage }}</span>
      </div>
    </div>
    {% endfor %}
  </div>

  <div class="js-reports"
       data-base-url="{{ app.request.getBaseURL() }}"
       data-error-message="{{ 'somethingWentWrong'|trans({}, 'catroweb') }}"
       data-empty-message="{{ 'You haven\'t filed any reports yet.'|trans({}, 'catroweb') }}"
       data-trans-project="{{ 'Project'|trans({}, 'catroweb') }}"
       data-trans-comment="{{ 'Comment'|trans({}, 'catroweb') }}"
       data-trans-user="{{ 'User'|trans({}, 'catroweb') }}"
       data-trans-studio="{{ 'Studio'|trans({}, 'catroweb') }}"
       data-trans-pending="{{ 'Pending'|trans({}, 'catroweb') }}"
       data-trans-accepted="{{ 'Accepted'|trans({}, 'catroweb') }}"
       data-trans-rejected="{{ 'Rejected'|trans({}, 'catroweb') }}"
  ></div>
{% endblock %}

{% block javascript %}
  {{ encore_entry_script_tags('user_reports_page') }}
{% endblock %}
