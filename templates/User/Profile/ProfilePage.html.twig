{% extends 'Layout/Base.html.twig' %}

{% block title %}{{ profile.username }} – Catrobat{% endblock %}

{% block head %}

  {{ encore_entry_link_tags('user_profile_page') }}
  {{ encore_entry_link_tags('user_follower_overview') }}
  {{ encore_entry_link_tags('user_profile_studios') }}

  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ profile.username|escape('html_attr') }} – Catrobat">
  <meta property="og:url" content="{{ url('profile', {id: profile.id}) }}">
  {% if profile.avatar is not empty %}
    {% set og_avatar_url = absolute_url(asset(profile.avatar)) %}
    <meta property="og:image" content="{{ og_avatar_url }}">
    <meta property="og:image:secure_url" content="{{ og_avatar_url }}">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ profile.username|escape('html_attr') }} – Catrobat">
    <meta name="twitter:image" content="{{ og_avatar_url }}">
  {% endif %}

{% endblock %}

{% block body %}

  <div class="row no-gutters profile">
    <div class="col-4 col-md-2 avatar-container mt-2 pe-3">
      <img alt="" id="user-image" class="img-fluid round"
           src="{% if profile.avatar is not empty %}{{ profile.avatar }}{% else %}{{ asset('images/default/avatar_default.png') }}{% endif %}"/>
    </div>

    <div id="user-information" class="col-8 col-md-10 mt-2 user-info d-flex flex-column justify-content-between">
      <h1 class="h4">{{ profile.username }} {% if profile.isVerified %}<i class="verification-icon material-icons">check</i>{% endif %}</h1>

      <div class="button-container w-100 mt-3">
        {% if profile.isScratchUser() %}
          <a href={{ 'https://scratch.mit.edu/users/' ~ profile.getScratchUsername() }}>
            <button class="btn btn-outline-primary profile-goto-scratch mt-0 ms-auto">
              {{ 'profile.goToScratchProfile'|trans({}, 'catroweb') }}
            </button>
          </a>
        {% endif %}
        {% if app.user != null and app.user.id != profile.id and not app.user.isMinor() and not profile.isMinor() %}
          <button class="btn btn-outline-primary profile-follows unfollow-btn mt-0 ms-auto"
                  style="{{ profile.hasFollower(app.user) ? 'display: block' : 'display:none' }}"
                  data-user-id="{{ profile.id }}"
                  data-user-name="{{ profile.username }}">
            {{ 'follower.follows'|trans({}, 'catroweb') }}
          </button>
          <button class="btn btn-primary profile-follow follow-btn mt-0 ms-auto"
                  style="{{ profile.hasFollower(app.user) ? 'display: none' : 'display:block' }}"
                  data-user-id="{{ profile.id }}">
            {{ 'follower.follow'|trans({}, 'catroweb') }}
          </button>
        {% endif %}
        {% if app.user == null %}
          <button class="btn btn-primary profile-follow follow-btn mt-0 mt-auto"
                  data-user-id="{{ profile.id }}">
            {{ 'follower.follow'|trans({}, 'catroweb') }}
          </button>
        {% endif %}
      </div>
    </div>
  </div>

  <div id="user-achievements" class="js-profile-achievements d-none mt-4 mb-2"
       data-base-url="{{ app.request.getBaseURL() }}"
       data-user-id="{{ profile.id }}"
       data-trans-title="{{ 'achievements.profile.title'|trans({}, 'catroweb') }}"
  ></div>

  <div class="tab-bar-container mt-3">
    <div class="mdc-tab-bar" role="tablist">
      <div class="mdc-tab-scroller">
        <div class="mdc-tab-scroller__scroll-area" id="scroll-area">
          <div class="mdc-tab-scroller__scroll-content">
            <button class="mdc-tab mdc-tab--active mdc-tab--stacked" role="tab" aria-selected="true" tabindex="0">
              <span class="mdc-tab__content">
                <span class="mdc-tab__icon" id="projects-count">{{ project_count }}</span>
                <span class="mdc-tab__icon-text">{{ 'projects'|trans({}, 'catroweb') }}</span>
              </span>
              <span class="mdc-tab-indicator mdc-tab-indicator--active">
                <span class="mdc-tab-indicator__content mdc-tab-indicator__content--underline"></span>
              </span>
            </button>

            {% if (not app.user or not app.user.isMinor()) and not profile.isMinor() %}
              <button class="mdc-tab mdc-tab--stacked" id="test" role="tab" aria-selected="false" tabindex="0">
                <span class="mdc-tab__content">
                  <span class="mdc-tab__icon" id="followers-count">-</span>
                  <span class="mdc-tab__icon-text">{{ 'follower.followers'|trans({}, 'catroweb') }}</span>
                </span>
                <span class="mdc-tab-indicator">
                  <span class="mdc-tab-indicator__content mdc-tab-indicator__content--underline"></span>
                </span>
              </button>

              <button class="mdc-tab mdc-tab--stacked" role="tab" aria-selected="false" tabindex="0">
                <span class="mdc-tab__content">
                  <span class="mdc-tab__icon" id="following-count">-</span>
                  <span class="mdc-tab__icon-text">{{ 'follower.follows'|trans({}, 'catroweb') }}</span>
                </span>
                <span class="mdc-tab-indicator">
                  <span class="mdc-tab-indicator__content mdc-tab-indicator__content--underline"></span>
                </span>
              </button>
            {% endif %}

            <button class="mdc-tab mdc-tab--stacked" role="tab" aria-selected="false" tabindex="0">
              <span class="mdc-tab__content">
                <span class="mdc-tab__icon" id="studios-count">-</span>
                <span class="mdc-tab__icon-text">{{ 'menu.studio'|trans({}, 'catroweb') }}</span>
              </span>
              <span class="mdc-tab-indicator">
                <span class="mdc-tab-indicator__content mdc-tab-indicator__content--underline"></span>
              </span>
            </button>

          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="tab-content mt-4">
    <div id="projects-section" class="tab-pane fade show active" role="tabpanel" aria-labelledby="projects-tab">
      <div id="user-projects"
           data-property="uploaded"
           data-theme="{{ theme() }}"
           data-base-url="{{ app.request.getBaseURL() }}"
           data-user-id="{{ profile.id }}"
           data-flavor="{{ flavor() }}"
           data-empty-message="{{ 'project.noProjects'|trans({}, 'catroweb') }}"
           data-show-actions="true"
           data-is-own-profile="{{ app.user is not null and app.user.id == profile.id ? 'true' : 'false' }}"
           data-is-logged-in="{{ app.user is not null ? 'true' : 'false' }}"
           data-project-detail-path="{{ path('program', {id: '__ID__'}) }}"
           data-trans-open="{{ 'project.open'|trans({}, 'catroweb')|default('Open')|e('html_attr') }}"
           data-trans-download="{{ 'project.download'|trans({}, 'catroweb')|default('Download')|e('html_attr') }}"
           data-trans-share="{{ 'project.shareAction'|trans({}, 'catroweb')|default('Share')|e('html_attr') }}"
           data-trans-delete="{{ 'project.deleteAction'|trans({}, 'catroweb')|default('Delete')|e('html_attr') }}"
           data-trans-report="{{ 'report.title'|trans({}, 'catroweb')|default('Report')|e('html_attr') }}"
           data-trans-share-success="{{ 'share.success'|trans({}, 'catroweb')|default('Link copied!')|e('html_attr') }}"
           data-trans-are-you-sure="{{ 'project.deleteConfirmationTitle'|trans({}, 'catroweb')|default('Are you sure?')|e('html_attr') }}"
           data-trans-delete-confirm="{{ 'project.deleteAction'|trans({}, 'catroweb')|default('Delete')|e('html_attr') }}"
           data-trans-cancel="{{ 'cancel'|trans({}, 'catroweb')|default('Cancel')|e('html_attr') }}"
           data-login-url="{{ path('login') }}"
           data-trans-report-title="{{ 'report.title'|trans({}, 'catroweb')|default('Report')|e('html_attr') }}"
           data-trans-report-submit="{{ 'report.submit'|trans({}, 'catroweb')|default('Submit')|e('html_attr') }}"
           data-trans-report-cancel="{{ 'report.cancel'|trans({}, 'catroweb')|default('Cancel')|e('html_attr') }}"
           data-trans-report-success="{{ 'report.success'|trans({}, 'catroweb')|default('Report submitted')|e('html_attr') }}"
           data-trans-report-error="{{ 'report.error'|trans({}, 'catroweb')|default('Error submitting report')|e('html_attr') }}"
           data-trans-report-duplicate="{{ 'report.duplicate'|trans({}, 'catroweb')|default('Already reported')|e('html_attr') }}"
           data-trans-report-trust-too-low="{{ 'report.trustTooLow'|trans({}, 'catroweb')|default('Trust too low')|e('html_attr') }}"
           data-trans-report-unverified="{{ 'report.unverified'|trans({}, 'catroweb')|default('Email verification required')|e('html_attr') }}"
           data-trans-report-suspended="{{ 'report.suspended'|trans({}, 'catroweb')|default('Account suspended')|e('html_attr') }}"
           data-trans-report-rate-limited="{{ 'report.rateLimited'|trans({}, 'catroweb')|default('Too many reports')|e('html_attr') }}"
           data-trans-report-placeholder="{{ 'report.placeholder'|trans({}, 'catroweb')|default('Please describe the issue...')|e('html_attr') }}"
           data-trans-retention-protected="{{ 'project.retention.protected'|trans({}, 'catroweb')|default('Protected')|e('html_attr') }}"
           data-trans-retention-day="{{ 'project.retention.day_left'|trans({}, 'catroweb')|default('1 day left')|e('html_attr') }}"
           data-trans-retention-days="{{ 'project.retention.days_left'|trans({'%days%': '%days%'}, 'catroweb')|default('%days% days left')|e('html_attr') }}"
           data-trans-retention-tooltip="{{ 'project.retention.tooltip'|trans({}, 'catroweb')|default('Projects are automatically removed after a period of inactivity. Get more downloads or log in regularly to extend retention.')|e('html_attr') }}"
           data-trans-retention-tooltip-protected="{{ 'project.retention.tooltip_protected'|trans({}, 'catroweb')|default('This project is protected and will not be automatically deleted.')|e('html_attr') }}"
           class="project-list loading project-list--full">
        <div class="container">
          <div class="lazyload projects-spinner-container">
            {{ include('Components/LoadingSpinner.html.twig', [], false) }}
          </div>
          <div class="lazyload project-list__wrapper">
            <div class="lazyload projects-container"></div>
          </div>
        </div>
      </div>
    </div>

    {% if (not app.user or not app.user.isMinor()) and not profile.isMinor() %}
      {{ include('User/Followers/FollowersTabs.twig') }}
    {% endif %}

    <div id="studios-section" class="tab-pane fade" role="tabpanel" aria-labelledby="studios-tab">
      <div id="no-studios" class="text-center mb-5 d-none">
        {{ 'studio.overview.no_studios'|trans({}, 'catroweb') }}
      </div>
      <div id="studio-cards" class="row mb-5">
        <div class="text-center py-3 studios-loading">
          {{ include('Components/LoadingSpinner.html.twig', [], false) }}
        </div>
      </div>
    </div>
  </div>

  {% if (not app.user or not app.user.isMinor()) and not profile.isMinor() %}
    {{ include('User/Followers/FollowerOverviewData.html.twig', {
      follower_user_id: profile.id,
      follower_user_role: app.user is not null ? 'user' : 'guest',
    }) }}
  {% endif %}

  <div class="js-profile-studios"
       data-user-id="{{ profile.id }}"
       data-base-url="{{ app.request.getBaseURL() }}"
       data-studio-details-path="{{ path('studio_details', {theme: theme(), id: '__ID__'}) }}"
       data-trans-no-studios="{{ 'studio.overview.no_studios'|trans({}, 'catroweb') }}"
  ></div>

{% endblock %}

{% block javascript %}
{{ encore_entry_script_tags('user_profile_page') }}
{{ encore_entry_script_tags('user_follower_overview') }}
{{ encore_entry_script_tags('user_profile_studios') }}
{% endblock %}
