{% extends 'Layout/Base.html.twig' %}
{% block top_bar_page_title %}{{ 'follower.followers'|trans({}, 'catroweb') }}{% endblock %}

{% block head %}
  {{ encore_entry_link_tags('user_follower_overview') }}
{% endblock %}

{% block body %}

    {{ include('Components/TabBar.html.twig', {
      tabs: [
        {
          id: 'follower-tab',
          title: 'follower.followers'|trans({}, 'catroweb'),
          count_id: 'followers-count',
          controls: 'follower-section',
        },
        {
          id: 'follows-tab',
          title: 'follower.follows'|trans({}, 'catroweb'),
          count_id: 'following-count',
          controls: 'following-section',
        },
      ],
    }) }}

  <div class="tab-content mt-4" aria-live="polite">
    <div id="follower-section" class="tab-pane fade show active" role="tabpanel" aria-labelledby="follower-tab">
      <div id="no-followers" class="text-center mb-5 d-none">
        {{ 'follower.noFollowers'|trans({}, 'catroweb') }}
      </div>

      <div id="follower-cards" class="row mb-5">
        {% for i in range(1, 4) %}
          <div class="col-12 my-3 js-skeleton">
            <div class="follower-item">
              <div class="follower-item__avatar">
                <span class="skeleton" style="display: block; width: 3.5rem; height: 3.5rem; border-radius: 50%;"></span>
              </div>
              <div class="follower-item__text" style="flex: 1;">
                <span class="skeleton" style="display: inline-block; width: 40%; height: 1rem;"></span>
                <div style="margin-top: 0.35rem;">
                  <span class="skeleton" style="display: inline-block; width: 25%; height: 0.85rem;"></span>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div id="following-section" class="tab-pane fade" role="tabpanel" aria-labelledby="follows-tab">
      <div id="no-following" class="text-center mb-5 d-none">
        {{ 'follower.noFollowing'|trans({}, 'catroweb') }}
      </div>

      <div id="following-cards" class="row mb-5">
        {% for i in range(1, 4) %}
          <div class="col-12 my-3 js-skeleton">
            <div class="follower-item">
              <div class="follower-item__avatar">
                <span class="skeleton" style="display: block; width: 3.5rem; height: 3.5rem; border-radius: 50%;"></span>
              </div>
              <div class="follower-item__text" style="flex: 1;">
                <span class="skeleton" style="display: inline-block; width: 40%; height: 1rem;"></span>
                <div style="margin-top: 0.35rem;">
                  <span class="skeleton" style="display: inline-block; width: 25%; height: 0.85rem;"></span>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {{ include('User/Followers/FollowerOverviewData.html.twig', {
    follower_user_id: user_id,
    follower_user_role: app.user is not null ? 'user' : 'guest',
  }) }}
{% endblock %}

{% block javascript %}
  {{ encore_entry_script_tags('user_follower_overview') }}
{% endblock %}
