{% extends '@SonataAdmin/CRUD/base_show_field.html.twig' %}

{% block field %}

  <button id="code-view{{ suffix|default('') }}"
          class="btn"
          onclick="location.href='{{ path('project', {id: object.id}) }}#code-view-inline'">
    <span>{{ 'codeview.title'|trans({}, 'catroweb') }}</span>
  </button>

{% endblock %}
