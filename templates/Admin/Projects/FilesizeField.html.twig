{% extends '@SonataAdmin/CRUD/base_list_field.html.twig' %}
{% block field %}
  {% set bytes = value %}
  {% if bytes >= 1048576 %}
    {{ '%.1f'|format(bytes / 1048576) }} MB
  {% elseif bytes >= 1024 %}
    {{ '%.1f'|format(bytes / 1024) }} KB
  {% else %}
    {{ bytes }} B
  {% endif %}
{% endblock %}
