{% extends 'Layout/Base.html.twig' %}

{% block head %}
  {{ encore_entry_link_tags('password_reset_page') }}
{% endblock %}

{% block body %}

<div class="content-card">
  <div class="row justify-content-center">
    <div class="login-container mb-4">

      <h1>{{ 'resetPassword.reset.title'|trans({}, 'catroweb') }}</h1>

      {% for flashError in app.flashes('reset_password_error') %}
        <div class="alert alert-danger">{{ flashError }}</div>
      {% endfor %}

      {{ form_start(resetForm, {attr: {novalidate: 'novalidate'}}) }}

        {% set firstField = resetForm.plainPassword.first %}
        {% set secondField = resetForm.plainPassword.second %}

        {# New password field #}
        <label id="new-password"
               class="mdc-text-field mdc-text-field--filled mdc-text-field--with-leading-icon mdc-text-field--with-trailing-icon">
          <span class="mdc-text-field__ripple"></span>
          <span class="mdc-floating-label" id="new-password__label">{{ firstField.vars.label|trans }}</span>
          <span class="material-icons mdc-text-field__icon mdc-text-field__icon--leading" role="button">lock</span>
          <input id="{{ firstField.vars.id }}"
                 class="mdc-text-field__input"
                 name="{{ firstField.vars.full_name }}"
                 type="password"
                 autocomplete="new-password"
                 required="required"
                 aria-labelledby="new-password__label"
                 tabindex="1">
          <span class="material-icons mdc-text-field__icon mdc-text-field__icon--trailing password-toggle"
                role="button" style="pointer-events: all;">visibility</span>
          <span class="mdc-line-ripple"></span>
        </label>
        <div class="mdc-text-field-helper-line mb-2">
          <div class="mdc-text-field-helper-text mdc-text-field-helper-text--persistent" id="new-password__helper" aria-hidden="true">
            {% if firstField.vars.errors|length > 0 %}
              <span class="text-danger">{{ firstField.vars.errors[0].message }}</span>
            {% endif %}
          </div>
        </div>

        {# Repeat password field #}
        <label id="repeat-password"
               class="mdc-text-field mdc-text-field--filled mdc-text-field--with-leading-icon mdc-text-field--with-trailing-icon">
          <span class="mdc-text-field__ripple"></span>
          <span class="mdc-floating-label" id="repeat-password__label">{{ secondField.vars.label|trans }}</span>
          <span class="material-icons mdc-text-field__icon mdc-text-field__icon--leading" role="button">lock</span>
          <input id="{{ secondField.vars.id }}"
                 class="mdc-text-field__input"
                 name="{{ secondField.vars.full_name }}"
                 type="password"
                 autocomplete="new-password"
                 required="required"
                 aria-labelledby="repeat-password__label"
                 tabindex="2">
          <span class="material-icons mdc-text-field__icon mdc-text-field__icon--trailing password-toggle"
                role="button" style="pointer-events: all;">visibility</span>
          <span class="mdc-line-ripple"></span>
        </label>
        <div class="mdc-text-field-helper-line mb-2">
          <div class="mdc-text-field-helper-text mdc-text-field-helper-text--persistent" id="repeat-password__helper" aria-hidden="true">
            {% if secondField.vars.errors|length > 0 %}
              <span class="text-danger">{{ secondField.vars.errors[0].message }}</span>
            {% endif %}
          </div>
        </div>

        {# Top-level errors (e.g., "passwords must match") #}
        {% if resetForm.plainPassword.vars.errors|length > 0 %}
          <div class="alert alert-danger mt-2">
            {{ resetForm.plainPassword.vars.errors[0].message }}
          </div>
        {% endif %}

        {{ form_widget(resetForm._token) }}

        <div class="mt-3">
          <button type="submit" class="btn btn-primary" tabindex="3">{{ 'resetPassword.reset.button.submit'|trans({}, 'catroweb') }}</button>
        </div>

      {{ form_end(resetForm, {render_rest: false}) }}

    </div>
  </div>
</div>
{% endblock %}

{% block javascript %}
{{ encore_entry_script_tags('password_reset_page') }}
{% endblock %}
