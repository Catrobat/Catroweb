{% extends 'Layout/Base.html.twig' %}

{% block body %}

<div class="content-card">
  <div class="row justify-content-center">
    <div class="login-container mb-4 text-center">

      <i class="material-icons" style="font-size: 4rem; color: #43a047;">check_circle</i>

      <h1 class="mt-3">{{ 'consent.confirmed.title'|trans({}, 'catroweb') }}</h1>

      <p class="mt-3 mb-4" style="font-size: 1.1rem;">
        {{ 'consent.confirmed.message'|trans({'%username%': username}, 'catroweb') }}
      </p>

      <a href="{{ path('index') }}" class="btn btn-primary">
        {{ 'consent.confirmed.continueButton'|trans({}, 'catroweb') }}
      </a>

    </div>
  </div>
</div>

{% endblock %}
