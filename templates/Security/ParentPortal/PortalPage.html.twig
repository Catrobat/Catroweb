{% extends 'Layout/Base.html.twig' %}

{% block head %}
  {{ encore_entry_link_tags('request_to_reset_password_page') }}
{% endblock %}

{% block body %}

<div class="content-card">
  <div class="row justify-content-center">
    <div class="login-container mb-4">

      <h1>{{ 'parent.portal.title'|trans({}, 'catroweb') }}</h1>

      {% for message in app.flashes('error') %}
        <div class="alert alert-danger mb-3">{{ message }}</div>
      {% endfor %}
      {% for message in app.flashes('success') %}
        <div class="alert alert-success mb-3">{{ message }}</div>
      {% endfor %}

      <p class="mb-4">{{ 'parent.portal.description'|trans({}, 'catroweb') }}</p>

      <div id="parent-portal-form"
           {{ stimulus_controller('security--parent-portal', {
             sendLinkPath: path('parent_send_link'),
             captchaEndpoint: captcha_enabled ? (captcha_public_url ~ '/' ~ captcha_site_key ~ '/') : '',
           }) }}>

        {{ include('Components/TextField.html.twig', {
          text_field: {
            id: 'parent-email',
            label: '' ~ 'parent.portal.emailLabel'|trans({}, 'catroweb'),
            name: '_email',
            type: 'email',
            leading_icon: 'email',
            tabindex: 1,
          },
        }) }}

        {% if captcha_enabled %}
          <div id="captcha-container" class="mb-3"></div>
        {% endif %}

        <div class="mt-3">
          <button type="button" id="parent-portal-submit"
                  data-action="click->security--parent-portal#requestManagementLink"
                  class="btn btn-primary">{{ 'parent.portal.submitButton'|trans({}, 'catroweb') }}</button>
          <a href="{{ path('parent_info') }}" class="btn btn-secondary">{{ 'parent.portal.infoLink'|trans({}, 'catroweb') }}</a>
        </div>
      </div>

      <div id="parent-portal-success" class="d-none">
        <div class="text-center py-4">
          <i class="material-icons" style="font-size: 3rem; color: var(--primary);">mark_email_read</i>
          <h3 class="mt-3">{{ 'parent.portal.success.title'|trans({}, 'catroweb') }}</h3>
          <p>{{ 'parent.portal.success.message'|trans({}, 'catroweb') }}</p>
        </div>
      </div>

    </div>
  </div>
</div>

{% endblock %}

{% block javascript %}
{{ encore_entry_script_tags('request_to_reset_password_page') }}
{% endblock %}
