{% extends 'Layout/Base.html.twig' %}

{% block og_meta %}
  <meta property="og:title" content="{{ 'meta.og.title.register'|trans({}, 'catroweb') }}">
  <meta property="og:description" content="{{ 'meta.og.description.register'|trans({}, 'catroweb') }}">
  <meta property="og:type" content="website">
{% endblock %}

{% block head %}
  {{ encore_entry_link_tags('registration_page') }}
{% endblock %}

{% block header '' %}

{% block body %}

  <div class="content-card">

    <div class="row justify-content-center">
      <div class="login-container mb-4">

        <h1>{{ 'register.title'|trans({}, 'catroweb') }}</h1>

        <div id="registration_form" role="form"
            {{ stimulus_controller('security--registration', {apiPath: path('open_api_server_users_userspost'), baseUrl: path('index'), captchaEndpoint: captcha_enabled ? (captcha_public_url ~ '/' ~ captcha_site_key ~ '/') : ''}) }}>

          {{ include('Components/TextField.html.twig', {
            text_field:
            {
              id: 'username',
              label: '' ~ 'login.username'|trans({}, 'catroweb'),
              name: '_username',
              leading_icon: 'person',
              tabindex: 1,
              autocomplete: 'username',
            },
          }) }}

          {{ include('Components/TextField.html.twig', {
            text_field:
            {
              id: 'email',
              label: '' ~ 'login.email'|trans({}, 'catroweb'),
              name: '_email',
              type: 'email',
              leading_icon: 'email',
              tabindex: 2,
              autocomplete: 'email',
            },
          }) }}

          {{ include('Components/TextField.html.twig', {
            text_field:
            {
              id: 'password',
              label: '' ~ 'password'|trans({}, 'catroweb'),
              name: '_password',
              type: 'password',
              trailing_icon: 'visibility',
              leading_icon: 'lock',
              tabindex: 3,
              autocomplete: 'new-password',
            },
          }) }}

          <div class="mb-2">
            <label id="date-of-birth" class="mdc-text-field mdc-text-field--filled mdc-text-field--with-leading-icon">
              <span class="mdc-text-field__ripple"></span>
              <span class="mdc-floating-label mdc-floating-label--float-above" id="date-of-birth__label">{{ 'register.dateOfBirth'|trans({}, 'catroweb') }}</span>
              <span class="material-icons mdc-text-field__icon mdc-text-field__icon--leading" role="button">cake</span>
              <input type="date" id="date-of-birth__input" name="_date_of_birth"
                     class="mdc-text-field__input" max="{{ 'now'|date('Y-m-d') }}" required
                     aria-labelledby="date-of-birth__label" tabindex="4">
              <span class="mdc-line-ripple"></span>
            </label>
            <div class="mdc-text-field-helper-line mb-2">
              <div class="mdc-text-field-helper-text mdc-text-field-helper-text--persistent" id="date-of-birth__helper" aria-hidden="true">
                {{ 'register.dateOfBirthInfo'|trans({}, 'catroweb') }}
              </div>
            </div>
          </div>

          <div id="parent-email-section" style="display: none;">
            <div class="mb-2">
              <label id="parent-email" class="mdc-text-field mdc-text-field--filled mdc-text-field--with-leading-icon">
                <span class="mdc-text-field__ripple"></span>
                <span class="mdc-floating-label mdc-floating-label--float-above" id="parent-email__label">{{ 'register.parentEmail'|trans({}, 'catroweb') }}</span>
                <span class="material-icons mdc-text-field__icon mdc-text-field__icon--leading" role="button">family_restroom</span>
                <input type="email" id="parent-email__input" name="_parent_email"
                       class="mdc-text-field__input"
                       aria-labelledby="parent-email__label" tabindex="5">
                <span class="mdc-line-ripple"></span>
              </label>
              <div class="mdc-text-field-helper-line mb-2">
                <div class="mdc-text-field-helper-text mdc-text-field-helper-text--persistent" id="parent-email__helper" aria-hidden="true">
                  {{ 'register.parentEmailInfo'|trans({}, 'catroweb') }}
                </div>
              </div>
            </div>
          </div>

          <p class="subtext">{{ 'register.subText'|trans({
              '%var1%': '<a id="privacyPolicy" href="' ~ path('privacypolicy') ~ '">' ~ 'privacyPolicy'|trans({}, 'catroweb') ~ '</a>',
              '%var2%': '<a id="termsOfUse" href="' ~ path('termsOfUse') ~ '">' ~ 'termsOfUse.title'|trans({}, 'catroweb') ~ '</a>',
            }, 'catroweb')|raw }}
          </p>

          {% if captcha_enabled %}
            <div id="captcha-container" class="mb-3"></div>
          {% endif %}

          <div class="mt-3" style="display: flex">
            <button type="submit" id="register-btn" data-action="click->security--registration#register"
                    class="btn btn-primary"
                    style="display: flex;">
              <span id="register-btn__spinner" class="d-none">
                {{ include('Components/LoadingSpinner.html.twig', {spinner_id: 'register-spinner' ~ suffix|default(), size: 'small'}) }}
              </span>
              <span id="register-btn__text ms-2">
                  {{ 'register.button.createAccount'|trans({}, 'catroweb') }}
              </span>
            </button>
            <a href="{{ path('login') }}"
               class="btn btn-secondary ms-1">{{ 'register.button.cancel'|trans({}, 'catroweb') }}</a>
          </div>

        </div>
      </div>
    </div>

    {{ include('Security/OauthRegistration.html.twig') }}

  </div>

{% endblock body %}

{% block javascript %}
{{ encore_entry_script_tags('registration_page') }}
{% endblock %}
