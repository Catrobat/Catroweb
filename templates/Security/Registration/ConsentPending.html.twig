{% extends 'Layout/Base.html.twig' %}

{% block body %}

<div class="content-card">
  <div class="row justify-content-center">
    <div class="login-container mb-4 text-center">

      <i class="material-icons" style="font-size: 4rem; color: #ff9800;">family_restroom</i>

      {% if is_revoked %}
        <h1 class="mt-3">{{ 'registration.consentRevoked.title'|trans({}, 'catroweb') }}</h1>
      {% else %}
        <h1 class="mt-3">{{ 'registration.consentPending.title'|trans({}, 'catroweb') }}</h1>
      {% endif %}

      {% for message in app.flashes('error') %}
        <div class="alert alert-danger mt-3">{{ message }}</div>
      {% endfor %}
      {% for message in app.flashes('success') %}
        <div class="alert alert-success mt-3">{{ message }}</div>
      {% endfor %}

      <p class="mt-3 mb-2" style="font-size: 1.1rem;">
        {% if is_revoked %}
          {{ 'registration.consentRevoked.message'|trans({}, 'catroweb') }}
        {% else %}
          {{ 'registration.consentPending.message'|trans({}, 'catroweb') }}
        {% endif %}
      </p>

      {% if parent_email %}
        <p class="mb-4" style="font-size: 1.1rem;">
          <strong>{{ 'registration.consentPending.sentTo'|trans({'%email%': parent_email}, 'catroweb') }}</strong>
        </p>
      {% endif %}

      <hr class="my-4">

      <details class="text-start">
        <summary class="text-muted" style="cursor: pointer;">{{ 'registration.consentPending.helpTitle'|trans({}, 'catroweb') }}</summary>
        <div class="mt-3 ps-2">

          <p class="text-muted small mb-3">{{ 'registration.consentPending.hint'|trans({}, 'catroweb') }}</p>

          <form method="post" action="{{ path('consent_resend') }}" class="mb-3">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('resend_consent') }}">
            <button type="submit" class="btn btn-sm btn-outline-secondary">
              {{ 'registration.consentPending.resendButton'|trans({}, 'catroweb') }}
            </button>
          </form>

          <p class="text-muted small mb-2">{{ 'registration.consentPending.wrongEmail'|trans({}, 'catroweb') }}</p>

          <form method="post" action="{{ path('consent_change_parent_email') }}" class="d-flex gap-2 align-items-start flex-wrap mb-2">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('change_parent_email') }}">
            <input type="email" name="parent_email" class="form-control form-control-sm" style="max-width: 260px;"
                   placeholder="{{ 'registration.consentPending.newEmailPlaceholder'|trans({}, 'catroweb') }}" required>
            <button type="submit" class="btn btn-sm btn-outline-secondary">
              {{ 'registration.consentPending.changeButton'|trans({}, 'catroweb') }}
            </button>
          </form>

        </div>
      </details>

    </div>
  </div>
</div>

{% endblock %}
