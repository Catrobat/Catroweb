{% extends 'Layout/Base.html.twig' %}

{% block body %}

<div class="content-card">
  <div class="row justify-content-center">
    <div class="login-container mb-4 text-center">

      <i class="material-icons" style="font-size: 4rem; color: #00acc1;">mark_email_unread</i>

      <h1 class="mt-3">{{ 'registration.verifyPending.title'|trans({}, 'catroweb') }}</h1>

      {% for message in app.flashes('error') %}
        <div class="alert alert-danger mt-3">{{ message }}</div>
      {% endfor %}
      {% for message in app.flashes('success') %}
        <div class="alert alert-success mt-3">{{ message }}</div>
      {% endfor %}

      <p class="mt-3 mb-4" style="font-size: 1.1rem;">
        {{ 'registration.verifyPending.message'|trans({}, 'catroweb') }}
      </p>

      <hr class="my-4">

      <details class="text-start">
        <summary class="text-muted" style="cursor: pointer;">{{ 'registration.verifyPending.helpTitle'|trans({}, 'catroweb') }}</summary>
        <div class="mt-3 ps-2">
          <p class="text-muted small mb-3">{{ 'registration.verifyPending.hint'|trans({}, 'catroweb') }}</p>
          <form method="post" action="{{ path('verify_resend') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('resend_verify') }}">
            <button type="submit" class="btn btn-sm btn-outline-secondary">
              {{ 'registration.verifyPending.resendButton'|trans({}, 'catroweb') }}
            </button>
          </form>
        </div>
      </details>

    </div>
  </div>
</div>

{% endblock %}
