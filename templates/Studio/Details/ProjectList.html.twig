<div id="projects-pane" class="tab-pane fade-in show active" role="tabpanel" aria-labelledby="projects-tab"
     {{ stimulus_controller('studio--project-list', {
       studioId: studio.id,
       projectsUrl: app.request.getBaseURL() ~ '/api/studio/' ~ studio.id ~ '/projects',
       addProjectUrl: app.request.getBaseURL() ~ '/api/studio/' ~ studio.id ~ '/projects',
       removeProjectUrl: app.request.getBaseURL() ~ '/api/studio/' ~ studio.id ~ '/projects/__PROJECT_ID__',
       userRole: user_role|default(''),
       isLoggedIn: user_name is defined and user_name ? true : false,
     }) }}
     data-trans-are-you-sure="{{ 'studio.details.are_you_sure'|trans({}, 'catroweb')|default('Are you sure?') }}"
     data-trans-no-way-of-return="{{ 'studio.details.no_way_of_return'|trans({}, 'catroweb')|default('This cannot be undone.') }}"
     data-trans-delete-it="{{ 'studio.details.delete_it'|trans({}, 'catroweb')|default('Delete') }}"
     data-trans-cancel="{{ 'cancel'|trans({}, 'catroweb')|default('Cancel') }}"
     data-trans-remove-error="{{ 'studio.details.remove_project_error'|trans({}, 'catroweb')|default('Failed to remove project.') }}"
     data-trans-add-project="{{ 'studio.details.projects.addProject'|trans({}, 'catroweb')|default('Add Projects') }}"
     data-trans-add="{{ 'studio.details.add'|trans({}, 'catroweb')|default('Add') }}"
     data-trans-no-available-projects="{{ 'studio.details.no_available_projects'|trans({}, 'catroweb')|default('No projects available to add.') }}"
     data-trans-open-project="{{ 'studio.details.projects.open_project'|trans({}, 'catroweb')|default('Open project') }}"
     data-trans-download="{{ 'studio.details.projects.download'|trans({}, 'catroweb')|default('Download') }}"
     data-trans-share="{{ 'studio.details.projects.share'|trans({}, 'catroweb')|default('Share') }}"
     data-trans-remove-from-studio="{{ 'studio.details.projects.remove_from_studio'|trans({}, 'catroweb')|default('Remove from studio') }}"
     data-trans-share-success="{{ 'studio.details.projects.share_success'|trans({}, 'catroweb')|default('Link copied to clipboard!') }}"
     data-trans-share-fail="{{ 'studio.details.projects.share_fail'|trans({}, 'catroweb')|default('Failed to copy link.') }}"
     data-trans-no-projects-empty-state="{{ 'studio.details.projects.no_projects_empty_state'|trans({}, 'catroweb')|default('You have no projects to add yet. Create one in Pocket Code first!') }}"
     data-trans-add-selected="{{ 'studio.details.projects.add_selected'|trans({}, 'catroweb')|default('Add Selected') }}"
>
  <p class="mt-3" id="studio-desc">{{ studio.description }}</p>
  <h3 class="mt-3">{{ 'studio.details.projects.title'|trans({}, 'catroweb') }}</h3>

  <div data-studio--project-list-target="container" class="studio-projects-container"></div>

  <p data-studio--project-list-target="noProjects" class="mt-3" style="display: none;">
    {{ 'studio.details.no_projects'|trans({}, 'catroweb') }}
  </p>

  <div data-studio--project-list-target="loadMore" style="display: none;" class="text-center mt-3">
    <button class="btn btn-outline-primary" data-action="click->studio--project-list#loadMore">
      {{ 'studio.details.showMore'|trans({}, 'catroweb')|default('Show More') }}
    </button>
  </div>

  {% if user_role == 'admin' or user_role == 'member' %}
    <button class="studios-fab"
            data-action="click->studio--project-list#openAddProjectModal">
      <span class="material-icons">add</span>
      <span class="studios-fab__text">{{ 'studio.details.projects.addProject'|trans({}, 'catroweb')|default('Add Project') }}</span>
    </button>
  {% endif %}
</div>
