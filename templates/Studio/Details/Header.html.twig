<div id="studio-header"
     class="studio-detail__header studio-detail__header--loading"
     data-studio-id="{{ studio.id }}"
     data-base-url="{{ app.request.getBaseURL() }}"
     data-login-url="{{ path('login') }}"
     data-is-logged-in="{{ app.user ? 'true' : 'false' }}"
     data-trans-public="{{ 'studio.public'|trans({}, 'catroweb') }}"
     data-trans-private="{{ 'studio.private'|trans({}, 'catroweb') }}"
     data-trans-leave="{{ 'studio.details.leave'|trans({}, 'catroweb') }}"
     data-trans-join="{{ 'studio.join'|trans({}, 'catroweb') }}"
     data-trans-pending="{{ 'studio.details.pending'|trans({}, 'catroweb') }}"
     data-trans-declined="{{ 'studio.details.decline'|trans({}, 'catroweb') }}"
     data-default-cover="{{ asset('images/default/studio_default.png') }}"
     data-trans-invalid-type="{{ 'studio.cover_image_invalid_type'|trans({}, 'catroweb') }}"
     data-trans-image-compressed="{{ 'studio.cover_image_compressed'|trans({}, 'catroweb') }}"
     data-trans-file-too-large="{{ 'studio.cover_image_still_too_large'|trans({}, 'catroweb') }}"
     data-trans-compression-failed="{{ 'studio.cover_image_compression_failed'|trans({}, 'catroweb') }}"
     data-trans-cover-hint="{{ 'studio.cover_image_hint'|trans({}, 'catroweb') }}"
     data-trans-promote-member="{{ 'studio.details.members_list.promote_member'|trans({}, 'catroweb') }}"
     data-trans-ban-member="{{ 'studio.details.members_list.ban_member'|trans({}, 'catroweb') }}"
     data-trans-promotion-failed="{{ 'studio.details.members_list.promotion_failed'|trans({}, 'catroweb') }}"
     data-trans-ban-failed="{{ 'studio.details.members_list.ban_failed'|trans({}, 'catroweb') }}"
     data-trans-demote-member="{{ 'studio.details.members_list.demote_member'|trans({}, 'catroweb') }}"
     data-trans-demotion-failed="{{ 'studio.details.members_list.demotion_failed'|trans({}, 'catroweb') }}"
     data-trans-no-studio-projects="{{ 'studio.details.members_list.no_studio_projects'|trans({}, 'catroweb') }}"
     data-trans-one-studio-project="{{ 'studio.details.members_list.one_studio_project'|trans({}, 'catroweb') }}"
     data-trans-n-studio-projects="{{ 'studio.details.members_list.n_studio_projects'|trans({'%count%': '%count%'}, 'catroweb') }}"
     data-trans-join-studio="{{ 'studio.details.activity_list.join_studio'|trans({'%user%': '%user%'}, 'catroweb') }}"
     data-trans-add-project="{{ 'studio.details.activity_list.add_project'|trans({'%user%': '%user%'}, 'catroweb') }}"
     data-trans-add-comment="{{ 'studio.details.activity_list.add_comment'|trans({'%user%': '%user%'}, 'catroweb') }}"
     data-trans-activity-title="{{ 'studio.details.activity_list.title'|trans({}, 'catroweb') }}"
     data-trans-members-title="{{ 'studio.details.members_list.title'|trans({}, 'catroweb') }}"
     data-trans-accept="{{ 'studio.details.join_requests.accept'|trans({}, 'catroweb') }}"
     data-trans-decline="{{ 'studio.details.join_requests.decline'|trans({}, 'catroweb') }}"
     data-trans-accept-success="{{ 'studio.details.join_requests.accept_success'|trans({}, 'catroweb') }}"
     data-trans-decline-success="{{ 'studio.details.join_requests.decline_success'|trans({}, 'catroweb') }}"
     data-trans-join-requests-error="{{ 'studio.details.join_requests.error'|trans({}, 'catroweb') }}"
     data-trans-no-requests="{{ 'studio.details.join_requests.no_requests'|trans({}, 'catroweb') }}"
     data-trans-join-requests-title="{{ 'studio.details.join_requests.title'|trans({}, 'catroweb') }}"
>

  <div id="studio-img-container" class="studio-detail__header__img__container">
    <img src="{{ studio.coverAssetPath ? asset(studio.coverAssetPath) : asset('images/default/studio_default.png') }}"
         class="img-fluid"
         alt="{{ studio.name }}"
         loading="eager"
         fetchpriority="high">
    <form class="studio-detail__header__details__button--upload-image" id="std-header-form"
          enctype="multipart/form-data" method="post" style="display: none">
      <span class="material-icons">photo_camera</span>
      <input id="std-header" name="header-img" type="file" accept="image/jpeg,image/png,image/gif,image/webp">
      <input id="studio-id" name="studio-id" type="hidden" value="{{ studio.id }}">
    </form>
    <span class="studio-cover-hint-wrap" style="display: none">
      <span class="material-icons studio-cover-hint-icon">info_outline</span>
      <span class="studio-cover-hint-tooltip"></span>
    </span>
  </div>

  <div class="container">
    <h2 class="studio-detail__header__name ps-3 pe-2 mt-2">{{ studio.name }}</h2>
    <div class="studio-detail__header__details container">

      <div class="col-3" id="header-visibility">
        <div class="studio-detail__header__details__info">
          {{ studio.isPublic ? 'studio.public'|trans({}, 'catroweb') : 'studio.private'|trans({}, 'catroweb') }}
        </div>
      </div>

      <div class="col-3" id="header-members">
        <div class="studio-detail__header__details__info">
          <span class="material-icons">person</span>
          <span class="ms-2 skeleton studio-detail__header__detail-skeleton-text js-studio-header-skeleton"></span>
        </div>
      </div>

      <div class="col-3" id="header-activities">
        <div class="studio-detail__header__details__info">
          <span class="material-icons">schedule</span>
          <span class="ms-2 skeleton studio-detail__header__detail-skeleton-text js-studio-header-skeleton"></span>
        </div>
      </div>

      <div class="col-3" id="header-join-requests" style="display: none"></div>

      <div class="col-3" id="header-action-button">
        <span class="skeleton studio-detail__header__action-skeleton js-studio-header-skeleton"></span>
      </div>
    </div>

    {{ include('Studio/Details/Tabs.html.twig') }}

  </div>
</div>
