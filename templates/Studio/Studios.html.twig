{% extends 'Layout/Base.html.twig' %}
{% block top_bar_page_title %}{{ 'studio.title'|trans({}, 'catroweb') }}{% endblock %}

{% block head %}
  {{ encore_entry_link_tags('studios_page') }}
{% endblock %}

{% block body %}
  <div {{ stimulus_controller('studio--overview', {
    apiBaseUrl: app.request.getBaseURL() ~ '/api',
    studioDetailsPath: path('studio_details', {id: '__ID__', theme: 'app'}),
    createStudioPath: is_logged_in ? path('studio_new') : path('login'),
    loginPath: path('login'),
    isLoggedIn: is_logged_in,
    userId: user_id|default(''),
  }) }}
    data-trans-public-studios="{{ 'studio.overview.public_studios'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-joined-studios="{{ 'studio.overview.joined_studios'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-private-studios="{{ 'studio.overview.private_studios'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-join="{{ 'studio.details.join'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-leave="{{ 'studio.details.leave'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-pending="{{ 'studio.details.pending'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-declined="{{ 'studio.details.decline'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-load-more="{{ 'studio.overview.load_more'|trans({}, 'catroweb')|default('Load More')|e('html_attr') }}"
    data-trans-no-studios="{{ 'studio.overview.no_studios'|trans({}, 'catroweb')|default('No studios found')|e('html_attr') }}"
    data-trans-my-studios="{{ 'studio.overview.my_studios'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-explore="{{ 'studio.overview.explore'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-no-joined="{{ 'studio.overview.no_joined'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-joined="{{ 'studio.overview.joined'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-open="{{ 'studio.overview.open'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-share="{{ 'studio.overview.share'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-share-success="{{ 'studio.overview.share_success'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-leave-confirm-title="{{ 'studio.overview.leave_confirm_title'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-cancel="{{ 'studio.overview.cancel'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-cancel-request="{{ 'studio.overview.cancel_request'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-cancel-request-confirm-title="{{ 'studio.overview.cancel_request_confirm_title'|trans({}, 'catroweb')|e('html_attr') }}"
    data-trans-admin="{{ 'studio.overview.admin'|trans({}, 'catroweb')|e('html_attr') }}"
  >
    {% if is_logged_in %}
      <section class="studios-section">
        <h2 class="studios-section__title" data-studio--overview-target="myStudiosHeader">{{ 'studio.overview.my_studios'|trans({}, 'catroweb') }}</h2>
        <div data-studio--overview-target="myStudios">
          {% for i in range(1, 3) %}
            {{ include('Studio/_SkeletonCard.html.twig') }}
          {% endfor %}
        </div>
        <div class="text-center my-3" data-studio--overview-target="loadMoreMy" style="display: none;">
          <button class="btn btn-outline-primary" data-action="click->studio--overview#loadMoreMy">
            {{ 'studio.overview.load_more'|trans({}, 'catroweb')|default('Load More') }}
          </button>
        </div>
      </section>

      <section class="studios-section">
        <h2 class="studios-section__title" data-studio--overview-target="exploreStudiosHeader">{{ 'studio.overview.explore'|trans({}, 'catroweb') }}</h2>
        <div data-studio--overview-target="exploreStudios">
          {% for i in range(1, 5) %}
            {{ include('Studio/_SkeletonCard.html.twig') }}
          {% endfor %}
        </div>
      </section>
    {% else %}
      <section class="studios-section">
        <h2 class="studios-section__title">{{ 'studio.overview.explore'|trans({}, 'catroweb') }}</h2>
        <div data-studio--overview-target="studiosList">
          {% for i in range(1, 5) %}
            {{ include('Studio/_SkeletonCard.html.twig') }}
          {% endfor %}
        </div>
      </section>
    {% endif %}

    <div id="studios-load-more" class="text-center my-3" data-studio--overview-target="loadMore" style="display: none;">
      <button class="btn btn-outline-primary" data-action="click->studio--overview#loadMore">
        {{ 'studio.overview.load_more'|trans({}, 'catroweb')|default('Load More') }}
      </button>
    </div>

    <a href="{{ is_logged_in ? path('studio_new') : path('login') }}"
       class="studios-fab">
      <span class="material-icons">add</span>
      <span class="studios-fab__text">{{ 'studio.create_studio'|trans({}, 'catroweb') }}</span>
    </a>
  </div>
{% endblock %}

{% block javascript %}
  {{ encore_entry_script_tags('studios_page') }}
{% endblock %}
